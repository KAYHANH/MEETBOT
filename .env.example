# MeetBot Environment Variables

# Quick start for GitHub reviewers:
# 1. Copy this file to .env
# 2. Keep DEMO_MODE and VITE_DEMO_MODE set to true
# 3. Run npm install && npm run dev

APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
VITE_API_URL=/api

# Demo mode lets the app run without Google OAuth or MongoDB.
DEMO_MODE=true
VITE_DEMO_MODE=true

# Required only when you want the real Google + MongoDB workflow.
MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/meetbot?ssl=true&replicaSet=your-replica-set&authSource=admin&appName=Cluster0
JWT_SECRET=replace_with_a_long_random_secret
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

LOG_LEVEL=info
